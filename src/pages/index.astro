---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import profilePhoto from '../assets/brian.png';
---

<Layout title="Home | Brian Rodríguez">
  <Header />

  <main class="max-w-4xl mx-auto px-6 py-28 space-y-32">

    <!-- ===================== -->
    <!-- PRESENTACIÓN          -->
    <!-- ===================== -->
    <section id="presentacion" class="space-y-10 text-center fade-in">

      <div class="inline-block px-4 py-1 text-sm rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300">
        Ingeniería de Sistemas · Universidad El Bosque
      </div>

      <h1 class="text-5xl font-bold tracking-tight text-gray-900 dark:text-white">
        Hola, soy
        <span class="bg-gradient-to-r from-indigo-600 via-purple-600 to-blue-600 bg-clip-text text-transparent">
          Brian
        </span>
      </h1>

      <!-- FOTO -->
      <div class="flex justify-center mt-8">
        <div class="relative w-44 h-44 group">
          <div class="absolute inset-0 rounded-full bg-gradient-to-r from-indigo-400 via-purple-400 to-blue-400 opacity-20 blur-xl group-hover:opacity-40 transition duration-500"></div>
          <div class="relative p-[3px] rounded-full bg-gradient-to-r from-indigo-500 via-purple-500 to-blue-500">
            <div class="rounded-full overflow-hidden bg-white dark:bg-gray-900">
              <img
                src={profilePhoto.src}
                alt="Foto de Brian Rodríguez"
                class="w-44 h-44 object-cover rounded-full transition-transform duration-500 group-hover:scale-105"
              />
            </div>
          </div>
        </div>
      </div>

      <div class="max-w-2xl mx-auto text-gray-700 dark:text-gray-300 leading-relaxed space-y-4">
        <p>
          Estudiante de Ingeniería de Sistemas enfocado en fortalecer
          sus bases técnicas y académicas.
        </p>
        <p>
          Este espacio funciona como mi portafolio académico
          para la asignatura Bases de Datos 1.
        </p>
      </div>

      <!-- VIDEO DE PRESENTACIÓN -->
      <div class="mt-16 flex justify-center">
        <div class="w-full max-w-4xl">
          <div class="text-center mb-6">
            <h2 class="text-2xl font-semibold text-gray-900 dark:text-white">Video de Presentación</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-2">
              Presentación personal y expectativas para Bases de Datos 1
            </p>
          </div>
          <div class="relative group">
            <div class="absolute inset-0 rounded-3xl bg-gradient-to-r from-indigo-400 via-purple-400 to-blue-400 opacity-20 blur-2xl group-hover:opacity-30 transition duration-500"></div>
            <div class="relative p-[3px] rounded-3xl bg-gradient-to-r from-indigo-500 via-purple-500 to-blue-500 shadow-xl">
              <div class="rounded-3xl overflow-hidden bg-black aspect-video">
                <iframe
                  class="w-full h-full"
                  src="https://www.youtube.com/embed/kwUVKb5iRRM"
                  title="Video de presentación"
                  frameborder="0"
                  allowfullscreen>
                </iframe>
              </div>
            </div>
          </div>
        </div>
      </div>

    </section>

    <!-- ========================= -->
    <!-- EVIDENCIAS                -->
    <!-- ========================= -->
    <section id="evidencias" class="space-y-24">

      <!-- Encabezado de sección -->
      <div class="text-center fade-in">
        <div class="inline-flex items-center gap-2 px-4 py-1 rounded-full bg-indigo-50 dark:bg-indigo-950/50 border border-indigo-200 dark:border-indigo-800 text-indigo-700 dark:text-indigo-300 text-sm font-medium mb-4">
          <span class="w-2 h-2 rounded-full bg-indigo-500 animate-pulse"></span>
          Portafolio académico · Bases de Datos 1
        </div>
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white">Evidencias</h2>
        <p class="text-gray-500 dark:text-gray-400 mt-2 text-sm">
          Ejercicios, talleres y proyectos desarrollados durante el curso
        </p>
      </div>

      <!-- ─────────────────────── -->
      <!-- MODELADO                -->
      <!-- ─────────────────────── -->
      <div id="modelado" class="space-y-8 fade-in">

        <!-- Encabezado subsección -->
        <div class="flex items-center gap-4">
          <div class="flex items-center justify-center w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-600 text-white shadow-md shadow-indigo-200 dark:shadow-indigo-900/50 flex-shrink-0">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900 dark:text-white">Modelado</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400">Diagramas Entidad-Relación desarrollados en clase</p>
          </div>
        </div>

        <div class="grid gap-6">

          <!-- Modelo 1 – Biblioteca -->
          <div class="group rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 overflow-hidden shadow-sm hover:shadow-lg hover:shadow-indigo-100 dark:hover:shadow-indigo-900/20 transition-all duration-300">

            <!-- Header -->
            <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 dark:border-gray-800">
              <div class="flex items-center gap-3">
                <span class="flex items-center justify-center w-7 h-7 rounded-lg bg-indigo-100 dark:bg-indigo-900/50 text-indigo-700 dark:text-indigo-300 text-xs font-bold">01</span>
                <h4 class="font-semibold text-gray-900 dark:text-white">Sistema Biblioteca</h4>
              </div>
              <span class="text-xs px-2.5 py-1 rounded-full bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300 font-medium">ER Diagrama</span>
            </div>

            <!-- Enunciado (colapsable) -->
            <details class="group/det border-b border-gray-100 dark:border-gray-800">
              <summary class="flex items-center gap-2 px-6 py-3 cursor-pointer select-none text-sm text-gray-500 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors list-none">
                <svg class="w-4 h-4 text-indigo-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                <span class="font-medium">Ver enunciado del ejercicio</span>
                <svg class="w-3.5 h-3.5 ml-auto transition-transform duration-200 group-open/det:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                </svg>
              </summary>
              <div class="px-6 pb-5 pt-3 bg-indigo-50/40 dark:bg-indigo-950/20">
                <p class="text-xs font-semibold text-indigo-600 dark:text-indigo-400 uppercase tracking-wider mb-3">Enunciado</p>
                <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed mb-4">
                  Crear un diseño E/R que permita gestionar los datos de una biblioteca de modo que:
                </p>
                <ul class="space-y-2.5 text-sm text-gray-600 dark:text-gray-400">
                  <li class="flex gap-2.5">
                    <span class="mt-1 w-4 h-4 rounded-full bg-indigo-100 dark:bg-indigo-900/60 text-indigo-600 dark:text-indigo-400 flex items-center justify-center flex-shrink-0 text-xs font-bold">1</span>
                    <span>Las personas socias de la biblioteca disponen de un código de socio y además se necesita almacenar su cédula, dirección, teléfono, nombre y apellidos.</span>
                  </li>
                  <li class="flex gap-2.5">
                    <span class="mt-1 w-4 h-4 rounded-full bg-indigo-100 dark:bg-indigo-900/60 text-indigo-600 dark:text-indigo-400 flex items-center justify-center flex-shrink-0 text-xs font-bold">2</span>
                    <span>La biblioteca almacena libros que presta a los socios; de ellos se almacena su título, año en el que se escribió, nombre completo del autor (o autores), año en que se editó, editorial e ISBN.</span>
                  </li>
                  <li class="flex gap-2.5">
                    <span class="mt-1 w-4 h-4 rounded-full bg-indigo-100 dark:bg-indigo-900/60 text-indigo-600 dark:text-indigo-400 flex items-center justify-center flex-shrink-0 text-xs font-bold">3</span>
                    <span>Se necesita poder indicar si un libro en la biblioteca está dañado o no.</span>
                  </li>
                </ul>
              </div>
            </details>

            <!-- Imagen del modelo -->
            <div class="p-4 overflow-hidden">
              <div class="rounded-xl overflow-hidden bg-gray-50 dark:bg-gray-950 group-hover:scale-[1.01] transition-transform duration-500">
                <img
                  src="/modelos/modelo1.png"
                  alt="Modelo Entidad Relación – Sistema Biblioteca"
                  class="w-full object-contain"
                />
              </div>
            </div>
          </div>

          <!-- Modelo 2 – Hospital Urgencias -->
          <div class="group rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 overflow-hidden shadow-sm hover:shadow-lg hover:shadow-indigo-100 dark:hover:shadow-indigo-900/20 transition-all duration-300">

            <!-- Header -->
            <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 dark:border-gray-800">
              <div class="flex items-center gap-3">
                <span class="flex items-center justify-center w-7 h-7 rounded-lg bg-indigo-100 dark:bg-indigo-900/50 text-indigo-700 dark:text-indigo-300 text-xs font-bold">02</span>
                <h4 class="font-semibold text-gray-900 dark:text-white">Sistema Hospital – Urgencias</h4>
              </div>
              <span class="text-xs px-2.5 py-1 rounded-full bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300 font-medium">ER Diagrama</span>
            </div>

            <!-- Enunciado (colapsable) -->
            <details class="group/det border-b border-gray-100 dark:border-gray-800">
              <summary class="flex items-center gap-2 px-6 py-3 cursor-pointer select-none text-sm text-gray-500 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors list-none">
                <svg class="w-4 h-4 text-indigo-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                <span class="font-medium">Ver enunciado del ejercicio</span>
                <svg class="w-3.5 h-3.5 ml-auto transition-transform duration-200 group-open/det:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                </svg>
              </summary>
              <div class="px-6 pb-5 pt-3 bg-indigo-50/40 dark:bg-indigo-950/20">
                <p class="text-xs font-semibold text-indigo-600 dark:text-indigo-400 uppercase tracking-wider mb-3">Enunciado</p>
                <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed mb-4">
                  Crear un diseño E/R que permita gestionar los datos de un Hospital de modo que:
                </p>
                <ul class="space-y-2.5 text-sm text-gray-600 dark:text-gray-400">
                  <li class="flex gap-2.5">
                    <span class="mt-1 w-4 h-4 rounded-full bg-indigo-100 dark:bg-indigo-900/60 text-indigo-600 dark:text-indigo-400 flex items-center justify-center flex-shrink-0 text-xs font-bold">1</span>
                    <span>Los pacientes tienen una cédula, dirección, teléfonos de contacto, nombre y apellidos, fecha de nacimiento y edad.</span>
                  </li>
                  <li class="flex gap-2.5">
                    <span class="mt-1 w-4 h-4 rounded-full bg-indigo-100 dark:bg-indigo-900/60 text-indigo-600 dark:text-indigo-400 flex items-center justify-center flex-shrink-0 text-xs font-bold">2</span>
                    <span>Los médicos del Hospital también tienen su cédula, nombre completo, especialidad y celular.</span>
                  </li>
                  <li class="flex gap-2.5">
                    <span class="mt-1 w-4 h-4 rounded-full bg-indigo-100 dark:bg-indigo-900/60 text-indigo-600 dark:text-indigo-400 flex items-center justify-center flex-shrink-0 text-xs font-bold">3</span>
                    <span>Se necesita poder indicar si un paciente ya pasó por Triage (en una fecha) y saber cuál es su nivel de esa evaluación.</span>
                  </li>
                </ul>
              </div>
            </details>

            <!-- Imagen del modelo -->
            <div class="p-4 overflow-hidden">
              <div class="rounded-xl overflow-hidden bg-gray-50 dark:bg-gray-950 group-hover:scale-[1.01] transition-transform duration-500">
                <img
                  src="/modelos/modeloHops.png"
                  alt="Modelo Entidad Relación – Hospital Urgencias"
                  class="w-full object-contain"
                />
              </div>
            </div>
          </div>

          <!-- Modelo 3 – Los Residuos Tóxicos -->
          <div class="group rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 overflow-hidden shadow-sm hover:shadow-lg hover:shadow-indigo-100 dark:hover:shadow-indigo-900/20 transition-all duration-300">
            <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 dark:border-gray-800">
              <div class="flex items-center gap-3">
                <span class="flex items-center justify-center w-7 h-7 rounded-lg bg-indigo-100 dark:bg-indigo-900/50 text-indigo-700 dark:text-indigo-300 text-xs font-bold">03</span>
                <h4 class="font-semibold text-gray-900 dark:text-white">Sistema de Residuos Tóxicos</h4>
              </div>
              <span class="text-xs px-2.5 py-1 rounded-full bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300 font-medium">ER Diagrama</span>
            </div>
            <details class="group/det border-b border-gray-100 dark:border-gray-800">
              <summary class="flex items-center gap-2 px-6 py-3 cursor-pointer select-none text-sm text-gray-500 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors list-none">
                <svg class="w-4 h-4 text-indigo-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                <span class="font-medium">Ver enunciado del ejercicio</span>
                <svg class="w-3.5 h-3.5 ml-auto transition-transform duration-200 group-open/det:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                </svg>
              </summary>
              <div class="px-6 pb-5 pt-3 bg-indigo-50/40 dark:bg-indigo-950/20">
                <p class="text-xs font-semibold text-indigo-600 dark:text-indigo-400 uppercase tracking-wider mb-3">Enunciado — Los Residuos Tóxicos</p>
                <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed mb-4">
                  Se desea abordar la problemática ambiental de los residuos tóxicos y peligrosos cuya incorrecta gestión produce daños de gran importancia en el medio ambiente y en la salud del ser humano. La información contemplada abarca desde que el residuo es producido por una empresa productora hasta que se encuentra en lugar seguro (incineración, almacenamiento en depósitos de seguridad, etc.). Se considera la información de los productores, los residuos, las empresas transportadoras y el traslado teniendo en cuenta el tipo de transporte y el envase.
                </p>
                <p class="text-xs font-semibold text-indigo-600 dark:text-indigo-400 uppercase tracking-wider mb-3">Supuestos semánticos</p>
                <ul class="space-y-2.5 text-sm text-gray-600 dark:text-gray-400">
                  <li class="flex gap-2.5">
                    <span class="mt-0.5 min-w-[1.25rem] h-5 rounded-md bg-indigo-100 dark:bg-indigo-900/60 text-indigo-600 dark:text-indigo-400 flex items-center justify-center text-xs font-bold">1</span>
                    <span>Una empresa productora produce un número amplio de residuos constituidos por un número variable de constituyentes químicos.</span>
                  </li>
                  <li class="flex gap-2.5">
                    <span class="mt-0.5 min-w-[1.25rem] h-5 rounded-md bg-indigo-100 dark:bg-indigo-900/60 text-indigo-600 dark:text-indigo-400 flex items-center justify-center text-xs font-bold">2</span>
                    <span>Más de una empresa productora puede producir residuos con igual número de constituyentes químicos y con las mismas o distintas cantidades.</span>
                  </li>
                  <li class="flex gap-2.5">
                    <span class="mt-0.5 min-w-[1.25rem] h-5 rounded-md bg-indigo-100 dark:bg-indigo-900/60 text-indigo-600 dark:text-indigo-400 flex items-center justify-center text-xs font-bold">3</span>
                    <span>Las empresas productoras asignan un código único a los residuos que producen. Más de una empresa puede asignar el mismo código a los residuos que produce.</span>
                  </li>
                  <li class="flex gap-2.5">
                    <span class="mt-0.5 min-w-[1.25rem] h-5 rounded-md bg-indigo-100 dark:bg-indigo-900/60 text-indigo-600 dark:text-indigo-400 flex items-center justify-center text-xs font-bold">4</span>
                    <span>Los residuos pueden ser trasladados en su totalidad, en partes, o no ser trasladados nunca.</span>
                  </li>
                  <li class="flex gap-2.5">
                    <span class="mt-0.5 min-w-[1.25rem] h-5 rounded-md bg-indigo-100 dark:bg-indigo-900/60 text-indigo-600 dark:text-indigo-400 flex items-center justify-center text-xs font-bold">5</span>
                    <span>En cada traslado la cantidad trasladada es enviada a un único destino.</span>
                  </li>
                  <li class="flex gap-2.5">
                    <span class="mt-0.5 min-w-[1.25rem] h-5 rounded-md bg-indigo-100 dark:bg-indigo-900/60 text-indigo-600 dark:text-indigo-400 flex items-center justify-center text-xs font-bold">6</span>
                    <span>En una misma fecha las empresas productoras pueden ordenar más de un traslado del mismo o distinto residuo (cantidades parciales) a un mismo o distinto destino.</span>
                  </li>
                  <li class="flex gap-2.5">
                    <span class="mt-0.5 min-w-[1.25rem] h-5 rounded-md bg-indigo-100 dark:bg-indigo-900/60 text-indigo-600 dark:text-indigo-400 flex items-center justify-center text-xs font-bold">7</span>
                    <span>En cada traslado puede intervenir más de una empresa transportista usando el mismo o distinto transporte; interesa conocer el medio, los kilómetros realizados y el coste.</span>
                  </li>
                  <li class="flex gap-2.5">
                    <span class="mt-0.5 min-w-[1.25rem] h-5 rounded-md bg-indigo-100 dark:bg-indigo-900/60 text-indigo-600 dark:text-indigo-400 flex items-center justify-center text-xs font-bold">8</span>
                    <span>El residuo se traslada en un tipo de envase determinado por la empresa productora, que no varía a lo largo del traslado.</span>
                  </li>
                  <li class="flex gap-2.5">
                    <span class="mt-0.5 min-w-[1.25rem] h-5 rounded-md bg-indigo-100 dark:bg-indigo-900/60 text-indigo-600 dark:text-indigo-400 flex items-center justify-center text-xs font-bold">9</span>
                    <span>Es interesante conocer la fecha de llegada a destino y el tratamiento al que se someten los residuos una vez alcanzado el mismo.</span>
                  </li>
                  <li class="flex gap-2.5">
                    <span class="mt-0.5 min-w-[1.25rem] h-5 rounded-md bg-indigo-100 dark:bg-indigo-900/60 text-indigo-600 dark:text-indigo-400 flex items-center justify-center text-xs font-bold">10</span>
                    <span>Por seguridad, en un traslado sólo puede trasladarse un residuo de una empresa productora.</span>
                  </li>
                </ul>
              </div>
            </details>
            <div class="p-4 overflow-hidden">
              <div class="rounded-xl overflow-hidden bg-gray-50 dark:bg-gray-950 group-hover:scale-[1.01] transition-transform duration-500">
                <img
                  src="/modelos/modelo_residuos.png"
                  alt="Modelo Entidad Relación – Sistema de Residuos Tóxicos"
                  class="w-full object-contain"
                />
              </div>
            </div>
          </div>

          <!-- Modelo 4 — PLACEHOLDER -->
          <div class="rounded-2xl border border-dashed border-indigo-200 dark:border-indigo-800/60 bg-indigo-50/40 dark:bg-indigo-950/20 overflow-hidden">
            <div class="flex items-center justify-between px-6 py-4 border-b border-dashed border-indigo-200 dark:border-indigo-800/60">
              <div class="flex items-center gap-3">
                <span class="flex items-center justify-center w-7 h-7 rounded-lg bg-indigo-100 dark:bg-indigo-900/50 text-indigo-400 dark:text-indigo-500 text-xs font-bold">04</span>
                <h4 class="font-semibold text-gray-400 dark:text-gray-600">Modelo 4 – [Nombre del sistema]</h4>
              </div>
              <span class="text-xs px-2.5 py-1 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-400 dark:text-gray-600 font-medium">Pendiente</span>
            </div>
            <div class="px-6 py-4 border-b border-dashed border-indigo-200 dark:border-indigo-800/60">
              <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-2">Enunciado</p>
              <p class="text-xs text-gray-400 dark:text-gray-500 italic">Pega aquí el enunciado del ejercicio cuando lo tengas...</p>
            </div>
            <div class="flex items-center justify-center h-28 text-gray-300 dark:text-gray-700">
              <div class="text-center">
                <svg class="w-7 h-7 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/>
                </svg>
                <p class="text-xs">Agrega la imagen de tu modelo aquí</p>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- ─────────────────────── -->
      <!-- NORMALIZACIÓN           -->
      <!-- ─────────────────────── -->
      <div id="normalizacion" class="space-y-8 fade-in">

        <div class="flex items-center gap-4">
          <div class="flex items-center justify-center w-10 h-10 rounded-xl bg-gradient-to-br from-purple-500 to-indigo-600 text-white shadow-md shadow-purple-200 dark:shadow-purple-900/50 flex-shrink-0">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
