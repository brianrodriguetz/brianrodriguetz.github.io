---
---

<nav class="fixed top-0 left-0 right-0 z-50 flex justify-center pt-3 sm:pt-6 px-4">
  <div class="relative backdrop-blur-md bg-white/80 dark:bg-gray-950/80 border border-gray-200 dark:border-gray-700 rounded-full px-5 py-3 flex items-center gap-6 shadow-sm w-full max-w-2xl sm:w-auto">

    <!-- Nombre -->
    <a href="/" class="text-sm font-semibold text-gray-900 dark:text-white whitespace-nowrap">
      Brian Rodríguez
    </a>

    <!-- Desktop Menu -->
    <div class="hidden sm:flex items-center gap-6 text-sm font-medium ml-auto">

      <a href="#presentacion"
         class="text-gray-600 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
        Presentación
      </a>

      <!-- Evidencias Dropdown -->
      <div class="relative group">
        <button class="flex items-center gap-1 text-gray-600 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
          Evidencias
          <svg class="w-3 h-3 transition-transform group-hover:rotate-180 duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>

        <!-- Dropdown -->
        <div class="absolute left-1/2 -translate-x-1/2 mt-4 w-44 rounded-2xl shadow-xl shadow-gray-200/50 dark:shadow-black/50 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0">

          <div class="p-1.5 space-y-0.5">
            <a href="#modelado" class="flex items-center gap-2.5 px-3 py-2.5 text-sm rounded-xl hover:bg-indigo-50 dark:hover:bg-indigo-950/50 hover:text-indigo-700 dark:hover:text-indigo-300 transition-colors text-gray-700 dark:text-gray-300">
              <span class="w-5 h-5 rounded-md bg-indigo-100 dark:bg-indigo-900/60 flex items-center justify-center">
                <svg class="w-3 h-3 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5z"/></svg>
              </span>
              Modelado
            </a>

            <a href="#normalizacion" class="flex items-center gap-2.5 px-3 py-2.5 text-sm rounded-xl hover:bg-purple-50 dark:hover:bg-purple-950/50 hover:text-purple-700 dark:hover:text-purple-300 transition-colors text-gray-700 dark:text-gray-300">
              <span class="w-5 h-5 rounded-md bg-purple-100 dark:bg-purple-900/60 flex items-center justify-center">
                <svg class="w-3 h-3 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2"/></svg>
              </span>
              Normalización
            </a>

            <a href="#sql" class="flex items-center gap-2.5 px-3 py-2.5 text-sm rounded-xl hover:bg-blue-50 dark:hover:bg-blue-950/50 hover:text-blue-700 dark:hover:text-blue-300 transition-colors text-gray-700 dark:text-gray-300">
              <span class="w-5 h-5 rounded-md bg-blue-100 dark:bg-blue-900/60 flex items-center justify-center">
                <svg class="w-3 h-3 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
              </span>
              SQL
            </a>

            <a href="#proyecto" class="flex items-center gap-2.5 px-3 py-2.5 text-sm rounded-xl hover:bg-green-50 dark:hover:bg-green-950/50 hover:text-green-700 dark:hover:text-green-300 transition-colors text-gray-700 dark:text-gray-300">
              <span class="w-5 h-5 rounded-md bg-green-100 dark:bg-green-900/60 flex items-center justify-center">
                <svg class="w-3 h-3 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
              </span>
              Proyecto
            </a>
          </div>
        </div>
      </div>

      <!-- Theme Toggle -->
      <button
        onclick="window.toggleTheme()"
        class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-gray-600 dark:text-gray-300"
        aria-label="Toggle theme">
        <!-- Sun (light mode) -->
        <svg class="w-4 h-4 dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
        </svg>
        <!-- Moon (dark mode) -->
        <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
        </svg>
      </button>

    </div>

    <!-- Mobile: Theme + Hamburger -->
    <div class="flex items-center gap-2 ml-auto sm:hidden">

      <button
        onclick="window.toggleTheme()"
        class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-gray-600 dark:text-gray-300"
        aria-label="Toggle theme">
        <svg class="w-4 h-4 dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/></svg>
        <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
      </button>

      <button id="mobile-menu-btn"
        class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-gray-600 dark:text-gray-300"
        aria-label="Abrir menú">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>

    </div>

  </div>

  <!-- Mobile Dropdown -->
  <div id="mobile-menu"
    class="absolute top-full left-4 right-4 mt-2 rounded-2xl shadow-xl shadow-gray-200/50 dark:shadow-black/50 bg-white/95 dark:bg-gray-900/95 backdrop-blur-md border border-gray-200 dark:border-gray-800 overflow-hidden hidden">
    <div class="p-3 space-y-1">
      <a href="#presentacion" class="mobile-link flex items-center gap-2 px-4 py-3 text-sm rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800 text-gray-700 dark:text-gray-300 font-medium transition-colors">
        Presentación
      </a>
      <div class="h-px bg-gray-100 dark:bg-gray-800 mx-2"></div>
      <p class="px-4 pt-1 pb-0.5 text-xs text-gray-400 dark:text-gray-600 font-semibold uppercase tracking-wider">Evidencias</p>
      <a href="#modelado" class="mobile-link flex items-center gap-3 px-4 py-2.5 text-sm rounded-xl hover:bg-indigo-50 dark:hover:bg-indigo-950/50 hover:text-indigo-700 dark:hover:text-indigo-300 text-gray-600 dark:text-gray-400 transition-colors">
        <span class="w-1.5 h-1.5 rounded-full bg-indigo-400"></span> Modelado
      </a>
      <a href="#normalizacion" class="mobile-link flex items-center gap-3 px-4 py-2.5 text-sm rounded-xl hover:bg-purple-50 dark:hover:bg-purple-950/50 hover:text-purple-700 dark:hover:text-purple-300 text-gray-600 dark:text-gray-400 transition-colors">
        <span class="w-1.5 h-1.5 rounded-full bg-purple-400"></span> Normalización
      </a>
      <a href="#sql" class="mobile-link flex items-center gap-3 px-4 py-2.5 text-sm rounded-xl hover:bg-blue-50 dark:hover:bg-blue-950/50 hover:text-blue-700 dark:hover:text-blue-300 text-gray-600 dark:text-gray-400 transition-colors">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-400"></span> SQL
      </a>
      <a href="#proyecto" class="mobile-link flex items-center gap-3 px-4 py-2.5 text-sm rounded-xl hover:bg-green-50 dark:hover:bg-green-950/50 hover:text-green-700 dark:hover:text-green-300 text-gray-600 dark:text-gray-400 transition-colors">
        <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span> Proyecto
      </a>
    </div>
  </div>

</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
    });
  });

  // Cerrar al click fuera
  document.addEventListener('click', (e) => {
    if (!btn?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
      menu?.classList.add('hidden');
    }
  });
</script>
